{
  "name": "agent-bundle",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "bin": {
    "agent-bundle": "dist/cli/index.js"
  },
  "scripts": {
    "ts:build": "tsc -p tsconfig.json",
    "ts:lint": "eslint \"spikes/**/*.{js,mjs,cjs,ts,mts,cts,tsx}\" \"src/**/*.{js,mjs,cjs,ts,mts,cts,tsx}\"",
    "ts:duplicate": "jscpd --config .jscpd.json",
    "ts:test": "vitest run --coverage",
    "ts:quality": "pnpm run ts:lint && pnpm run ts:duplicate && pnpm run ts:test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "jscpd": "^4.0.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "citty": "^0.2.1",
    "e2b": "^2.12.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
