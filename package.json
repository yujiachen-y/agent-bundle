{
  "name": "agent-bundle-quality",
  "private": true,
  "type": "module",
  "scripts": {
    "ts:lint": "eslint \"spikes/**/*.{js,mjs,cjs,ts,mts,cts,tsx}\"",
    "ts:duplicate": "jscpd --config .jscpd.json",
    "ts:test": "vitest run --coverage",
    "ts:quality": "npm run ts:lint && npm run ts:duplicate && npm run ts:test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "jscpd": "^4.0.5",
    "typescript-eslint": "^8.46.4",
    "vitest": "^3.2.4"
  }
}
