{
  "name": "system-prompt-spike",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "node ./src/generate-system-prompt.mjs --bundle ./bundle.sample.yaml --out ./dist/system-prompt.txt",
    "generate:desc": "node ./src/generate-system-prompt.mjs --bundle ./bundle.description-only.yaml --out ./dist/system-prompt.description-only.txt",
    "generate:full": "node ./src/generate-system-prompt.mjs --bundle ./bundle.full.yaml --out ./dist/system-prompt.full.txt",
    "runtime": "node ./src/measure-runtime.mjs",
    "tokens": "node ./src/measure-tokens.mjs",
    "e2e": "node ./src/e2e-pi-mono.mjs",
    "run": "npm run generate && npm run runtime && npm run tokens && npm run e2e"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.14.2",
    "dotenv": "^16.4.5",
    "js-tiktoken": "^1.0.14",
    "yaml": "^2.6.0"
  }
}
